---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" metadesc="Welcome to Lakshyaraj's Portfolio website!">
	<div class="container p-6 lg:p-10 my-3">
		<section class="text-gray-600 body-font">
			<div class="container mx-auto flex md:flex-row flex-col items-center">
			  <div class="lg:flex-grow md:w-1/2 lg:pr-24 md:pr-16 flex flex-col md:items-start md:text-left mb-16 md:mb-0 items-center text-center">
				<h1 class="title-font sm:text-4xl text-3xl mb-4 font-medium text-gray-900">&lt;Lakshyaraj Dash/&gt;</h1>
				<p class="mb-8 leading-relaxed">I am a web developer enthusiast. Love to solve problems and face challenges. Browse my projects and my blog.</p>
				<div class="flex justify-center">
				  <a href="/projects" class="inline-flex text-white bg-indigo-500 border-0 py-2 px-6 focus:outline-none hover:bg-indigo-600 rounded text-lg">Browse Projects</a>
				  <a href="/blog" class="ml-4 inline-flex text-gray-700 bg-gray-100 border-0 py-2 px-6 focus:outline-none hover:bg-gray-200 rounded text-lg">Browse Blog</a>
				</div>
			  </div>
			  <div class="lg:max-w-lg lg:w-full md:w-1/2 w-5/6">
				<img class="object-cover object-center rounded" alt="hero" src="/images/hero.jpg">
			  </div>
			</div>
		  </section>
	</div>
</Layout>
